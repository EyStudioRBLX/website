NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-super-secret-key-here-change-in-production

# Discord OAuth2 — get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# MongoDB — e.g. mongodb+srv://user:pass@cluster.mongodb.net/eystudio
MONGODB_URI=mongodb://localhost:27017/eystudio

# Discord Webhook for application notifications (optional)
DISCORD_WEBHOOK_URL=your-discord-webhook-url

# Public app URL (used in webhook links)
NEXT_PUBLIC_APP_URL=http://localhost:3000
